PORT=8011
DATABASE_URL=postgres://postgres:postgres@localhost:5432/csv_ingestion

# Datasets oficiales de datos.gob.ar a sincronizar.
DATASET_IDS=seguridad-snic---total-pais-estadisticas-criminales-republica-argentina,seguridad-snic---provincial-estadisticas-criminales-republica-argentina-por-provincias,seguridad-estadisticas-sobre-uso-racional-fuerza-empleo-armas-fuego-fuerzas-federales

# Datasets oficiales de datos.jus.gob.ar a sincronizar.
JUSTICIA_DATASET_IDS=internos-del-servicio-penitenciario-federal-spf

# Formatos de recursos a ingerir desde cada dataset.
RESOURCE_FORMATS=CSV,XLSX

# Cron en formato node-cron. Default: cada 24 hs, a medianoche.
SYNC_CRON=0 0 * * *

# Opcional: hashes esperados por resource id, separados por coma.
# Ejemplo: seguridad_1.2=abc123,seguridad_2.2=def456
EXPECTED_RESOURCE_SHA256=
